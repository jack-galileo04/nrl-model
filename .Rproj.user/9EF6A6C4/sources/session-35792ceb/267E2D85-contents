```{r}
# Scaled form statistics

library(qcc) ; lambda <- 0.94

player_forms_df <- player_df |> 
  unite("name", firstname:surname, sep = "_") |> 
  mutate(conversion_attempts = ifelse(conversion_attempts == 0, NA, conversion_attempts),
         penalty_goal_attempts = ifelse(penalty_goal_attempts == 0, NA, penalty_goal_attempts),
         possessions = ifelse(possessions == 0, NA, possessions)) |> 
  mutate(goal_kick_ratio = (conversions+penalty_goals) / (conversion_attempts+penalty_goal_attempts)) |> 
  select(-conversions, -conversion_attempts, -penalty_goals, -penalty_goal_attempts,
         -runs_hitup, -runs_normal, -runs_hitup_metres, -runs_normal_metres, -tackleds, -handling_errors, -post_contact_metres) |> 
  left_join(position_minutes_weights, by = "position") |> 
  mutate(
    m_per_run=run_metres/runs,tb_per_run=tackle_breaks/runs,lb_per_run=line_breaks/runs,offs_per_run=offloads/runs, # Attacking Runs
    ta_per_touch=try_assists/possessions,lba_per_touch=line_break_assists/possessions,kick_per_touch=kicks_general_play/possessions,pass_per_touch=passes/possessions,
      km_per_kick=ifelse(kicks_general_play ==0, NA, kick_metres/kicks_general_play),goals_per_kick=goal_kick_ratio, # Attacking Play-making
    tries_per_game=tries,err_per_touch=errors/possessions,points_per_game=points, # Attacking Overall
    tackles_time=tackles/w,saves_per_game=try_saves, # Defensive Work
    miss_per_t=missed_tackles/tackles,pen_per_t=penalties_conceded/tackles,ineff_per_t=tackles_ineffective/tackles # Defensive Discipline
  ) |> 
  select(-goal_kick_ratio,-(12:30)) |> 
  group_by(player_id) |> 
  arrange(player_id, utc_start) |> 
  select(utc_start, name, player_id, team_name, jumper_number, position, squad_id, match_id, competition_id, season, round,
         team_location, everything()) |> 
  mutate(across(
    13:30,
    .fns = ~ lag(accumulate(., ~lambda*.x + (1-lambda)*.y ), n=1)
    )) |> 
  ungroup() |> 
  group_by(competition_id, round, position) |> 
  mutate(across(
    11:28,
    .fns = ~scale(.x)
  )) |> 
  ungroup()
```

```{r}
# Group statistics into channels (work about better weighted average)

player_channels_df <- player_forms_df |> 
  rowwise() |> 
  mutate(
    att_runs = mean(c(m_per_run,tb_per_run,lb_per_run,offs_per_run), na.rm = TRUE),
    att_plays = mean(c(ta_per_touch,lba_per_touch,kick_per_touch,pass_per_touch,km_per_kick,goals_per_kick), na.rm = TRUE),
    att_overall = mean(c(tries_per_game,-err_per_touch,points_per_game), na.rm = TRUE),
    def_work = mean(c(tackles_time,saves_per_game), na.rm = TRUE),
    def_disc = mean(c(miss_per_t,pen_per_t,ineff_per_t), na.rm = TRUE)
  ) |> 
  ungroup() |> 
  select(-(13:31)) |> 
  group_by(competition_id, round, position) |> 
  mutate(across(
    10:13,
    .fns = ~scale(.x)
  )) |> 
  ungroup() |> 
  left_join(team_and_recovery_df |> select(match_id, team_name, score), by = c("match_id", "team_name"))
```

```{r}
# Gauging general importance of each channel for scoring

channel_effects_df <- player_channels_df |> 
  group_by(match_id, team_name) |> 
  reframe(
    across(11:15, ~ mean(.x, na.rm = TRUE)),
    score = first(score),
    date = first(utc_start),
    team_location = first(team_location)
  ) |> 
  drop_na() |> 
  arrange(match_id) |> 
  group_by(match_id) |> 
  mutate(opponent_score = rev(score),
         score_diff = score - opponent_score) |> 
  ungroup()

lm_fit_att <- lm(sqrt(score) ~  def_disc + att_runs + att_plays + att_overall + def_work, data = channel_effects_df)
summary(lm_fit_att) # att_overall > att_runs > att_plays
lm_fit_def <- lm(sqrt(opponent_score) ~  def_disc + att_runs + att_plays + att_overall + def_work, data = channel_effects_df)
summary(lm_fit_def) # att_overal > att_runs > att_plays > def_work
lm_fit_diff <- lm(sqrt(score_diff) ~  def_disc + att_runs + att_plays + att_overall + def_work, data = channel_effects_df)
summary(lm_fit_diff) # att_overal > att_runs > att_plays > def_work
# Defensive work appears to be a negative (less posession etc)

channel_effects_df |> 
  summarise(mean_score = mean(score))

channel_effects_df |> 
  group_by(team_location) |> 
  summarise(mean_score = mean(score))
```

```{r}

model_data <- channel_effects_df |> 
  select(-opponent_score, -score_diff) |> 
  mutate(
    roster_strength = 0.4 * att_overall + 0.2 * att_runs + 0.2 * att_plays - 0.15 * def_work + 0.05 * def_disc
    ) |> 
  select(match_id, date, team = team_name, score, team_location, roster_strength) |> 
  pivot_wider(
    names_from = team_location,
    values_from = c(score, team, roster_strength)
  ) |> 
  mutate(
    team_away = factor(team_away),
    team_home = factor(team_home),
    match_id = factor(match_id),
    R_diff_home = scale(roster_strength_home - roster_strength_away),
    R_diff_away = scale(roster_strength_away - roster_strength_home),
    HA = 1
  ) |> 
  select(-roster_strength_home, roster_strength_away) |> 
  drop_na()

model_data_long <- bind_rows(
  model_data |> 
    transmute(
      match_id,
      date,
      team = team_home,
      opponent = team_away,
      score = score_home,
      is_home = 1L,
      R_diff = R_diff_home
    ),
  model_data |> 
    transmute(
      match_id,
      date,
      team = team_away,
      opponent = team_home,
      score = score_away,
      is_home = 0L,
      R_diff = R_diff_away
    )
)
```


```{r}
library(brms)

priors <- c(
  prior(normal(log(20), 0.5), class = "Intercept"),

  prior(normal(0.11, 0.11), class = "b", coef = "is_home"),

  prior(normal(0, 0.02), class = "b", coef = "R_diff"),

  prior(exponential(3), class = "sd"),
  
  prior(inv_gamma(0.4, 0.3), class = "shape")  # Modern method
)


fit <- brm(
  score ~ 1 + is_home + R_diff +
    (1 | team) +          # attack (a_team)
    (1 | opponent),      # opponent effect
  data = model_data_long,
  family = negbinomial(),
  prior = priors,
  chains = 4, cores = 4, iter = 4000,
  control = list(adapt_delta = 0.95, max_treedepth = 12)
)
```
