```{r}
# Team attack and defence strengths
library(tidybayes)

attack <- ranef(fit)$team[, , "Intercept"] |>
  as.data.frame() |>
  tibble::rownames_to_column("team") |>
  rename(
    att_mean = Estimate,
    att_lo = Q2.5,
    att_hi = Q97.5
  )

defence <- ranef(fit)$opponent[, , "Intercept"] |>
  as.data.frame() |>
  tibble::rownames_to_column("team") |>
  rename(
    def_mean_raw = Estimate,
    def_lo_raw = Q2.5,
    def_hi_raw = Q97.5
  ) |>
  mutate(
    def_mean = -def_mean_raw,
    def_lo   = -def_hi_raw,
    def_hi   = -def_lo_raw
  )
```

