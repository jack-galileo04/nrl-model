```{r setup, include=FALSE}
knitr::opts_chunk$set(echo = TRUE)

library(tidyverse)
library(tidymodels)
library(lubridate)
library(here)

model_data <- read.csv(here("Data/Processed/feature_engineered.csv")) |> 
  select(result, everything()) |> 
  mutate(result = factor(result), result == ifelse(result == "H", "H", "A")) |> 
  mutate(date = as_date(date))
```

```{r Tune Results xgb}

xgb_tune_res <- readRDS(here("Outputs/Models/xgb_tune_res.rds"))

xgb_tune_res |> collect_metrics()
xgb_tune_res |> show_best(metric = "mn_log_loss")
xgb_best_logloss <- xgb_tune_res |> select_best(metric = "mn_log_loss")

p <- xgb_tune_res |> 
  collect_metrics() |> 
  filter(.metric == "mn_log_loss") |> 
  select(mean, mtry:sample_size) |> 
  pivot_longer(mtry:sample_size,
               names_to = "parameter",
               values_to = "value") |> 
  ggplot(aes(value, mean, color = parameter)) +
  geom_point() +
  facet_wrap(~parameter, scales = "free_x")

ggsave(plot = p, filename = here("Outputs/Plots/xgb_tune_results.png"))

# Low loss reduction, 0.004 or above for learn rate
```

