```{r Model Stack Data Split (same split)}

stack_train_data <- train_data |> 
  select(date, result) |> 
  bind_cols(predict(final_lasso, train_data, type = "prob") |> rename(lasso_A = .pred_A, lasso_H = .pred_H),
            predict(final_xgb, train_data, type = "prob") |> rename(xgb_A = .pred_A, xgb_H = .pred_H),
            predict(final_xgb, train_data, type = "prob") |> rename(rf_A = .pred_A, rf_H = .pred_H))

stack_test_data <- test_data |> 
  select(date, result) |> 
  bind_cols(predict(final_lasso, test_data, type = "prob") |> rename(lasso_A = .pred_A, lasso_H = .pred_H),
            predict(final_xgb, test_data, type = "prob") |> rename(xgb_A = .pred_A, xgb_H = .pred_H),
            predict(final_xgb, test_data, type = "prob") |> rename(rf_A = .pred_A, rf_H = .pred_H))
```

```{r Validation Folds}

N <- nrow(stack_train_data)
number_folds <- 5
assess <- 500
skip <- 100
initial <- -(number_folds*skip+assess-N)

stack_folds <- rolling_origin(
  data = stack_train_data,
  initial = initial,
  assess = assess,
  skip = skip,
  cumulative = TRUE
)

stack_data <- stack_train_data |> bind_rows(stack_test_data)
stack_split <- initial_time_split(stack_data, prop = 0.875475)
```

```{r Lasso Regression to Ensamble}

stack_model <- logistic_reg(penalty = tune(), mixture = tune()) |> 
  set_mode("classification") |> 
  set_engine("glmnet")

stack_rec <- recipe(result ~ ., data = stack_train_data) |> 
  step_rm(date) |> 
  step_normalize(all_numeric_predictors()) |> 
  step_zv() |> 
  step_nzv() |> 
  step_impute_knn(all_numeric_predictors(), neighbors = 5)

stack_wf <- workflow() |> 
  add_recipe(stack_rec) |> 
  add_model(stack_model)

stack_grid <- grid_regular(
  penalty(range = c(-6,0)),
  mixture(range = c(0,1)),
  levels = c(10,5)
)

stack_res <- tune_grid(
  stack_wf, resamples = stack_folds, grid = stack_grid, metrics = metrics, control = control_grid(save_pred = TRUE)
)
saveRDS(stack_res, here("Outputs/Models/stack_res.rds"))

best_logloss <- stack_res |> select_best(metric = "mn_log_loss")
```

```{r Final Ensamble Fit}

final_stack_wf <- finalize_workflow(stack_wf, best_logloss)

final_stack_fit <- last_fit(final_stack_wf, stack_split, metrics = metrics)
saveRDS(final_stack_fit, here("Outputs/Models/final_stack_fit.rds"))

final_metrics <- collect_metrics(final_stack_fit) |> 
  select(metric = .metric, estimate = .estimate) |> 
  pivot_wider(names_from = metric, values_from = estimate)

test_preds <- collect_predictions(final_stack_fit) |> slice_tail(n = 426) |> 
  bind_cols(test_data |> select(home_team, away_team, date)) |> 
  select(-.config, -.row, -id) |> 
  arrange(desc(date))

log_experiment(algorithm = "final stack",
               feature_set = feature_set,
               resample_scheme = "5 cv folds",
               logloss = final_metrics$mn_log_loss,
               notes = "")
```

