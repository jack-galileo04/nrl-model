  mutate(utc_start = as_date(utc_start))
```


```{r}
library(brms)

priors <- c(
  prior(normal(log(20), 0.5), class = "Intercept"),

  prior(normal(0.11, 0.11), class = "b", coef = "is_home"),

  prior(normal(0, 0.02), class = "b", coef = "R_diff"),

  prior(exponential(3), class = "sd"),
  
  prior(inv_gamma(0.4, 0.3), class = "shape")  # Modern method
)


fit <- brm(
  score ~ 1 + is_home + R_diff +
    (1 | team) +          # attack (a_team)
    (1 | opponent),      # opponent effect
  data = model_data_long,
  family = negbinomial(),
  prior = priors,
  chains = 4, cores = 4, iter = 4000,
  control = list(adapt_delta = 0.95, max_treedepth = 12)
)
```
```{r}
# Sample Diagnostics

summary(fit)
# Rhats ok
# Bulk and Tail ESS ok
```

```{r, fig.height = 10, fig.width = 12}
plot(fit)
```

```{r}
# Posterior Predictive Checks

pp_check(fit)
pp_check(fit, type = "error_hist", ndraws = 11)
pp_check(fit, type = "scatter_avg", ndraws = 100)
# Mostly moded around 15 ish
# Big scores can happen and these are reallistic
```

```{r}
# Team attack and defence strengths
library(tidybayes)

attack <- ranef(fit)$team[, , "Intercept"] |>
  as.data.frame() |>
  tibble::rownames_to_column("team") |>
  rename(
    att_mean = Estimate,
    att_lo = Q2.5,
    att_hi = Q97.5
  )

defence <- ranef(fit)$opponent[, , "Intercept"] |>
  as.data.frame() |>
  tibble::rownames_to_column("team") |>
  rename(
    def_mean_raw = Estimate,
    def_lo_raw = Q2.5,
    def_hi_raw = Q97.5
  ) |>
  mutate(
    def_mean = -def_mean_raw,
    def_lo   = -def_hi_raw,
    def_hi   = -def_lo_raw
  )
```

```{r}
# Ranked attack plot

attack |>
  mutate(team = reorder(team, att_mean)) |>
  ggplot(aes(att_mean, team)) +
  geom_point() +
  geom_errorbarh(aes(xmin = att_lo, xmax = att_hi), height = 0) +
  geom_vline(xintercept = 0, linetype = "dashed") +
  labs(
    title = "Team attack strength (log scale)",
    x = "Attack effect (log points)",
    y = NULL
  )

# Over the course of the past 10 years, this makes sense. Not necessarily to date.
```
