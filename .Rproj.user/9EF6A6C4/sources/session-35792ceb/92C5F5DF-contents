```{r}
# Home advantage and roster effects

fixef(fit)
# Having a roster strength advantage is less important than home ground advantage.

exp(fixef(fit)["is_home", "Estimate"])     # home multiplier
exp(fixef(fit)["R_diff",  "Estimate"])     # per 1 SD roster edge

# 7% multiplicative boost in roster differences (given teams are already accounted for), if scale is 1
# 12% boost by home advantage.
```
```{r}
model_data_random_walk <- model_data_long |> 
  arrange(date) |> 
  mutate(
    time_idx = as.integer(factor(date, ordered = TRUE))
  ) |> 
  select(match_id, time_idx, everything(), -date)
```



```{r}
priors_random_walk <- c(
  prior(normal(log(20), 0.5), class = "Intercept"),

  prior(normal(0.11, 0.11), class = "b", coef = "is_home"),

  prior(normal(0, 0.02), class = "b", coef = "R_diff"),

  prior(exponential(3), class = "sd"),
  
  prior(exponential(5), class = "sd", group = "team:time_idx"),
  prior(exponential(5), class = "sd", group = "opponent:time_idx"),

  
  prior(inv_gamma(0.4, 0.3), class = "shape")  # Modern method
)


fit_random_walk <- brm(
  score ~ 1 + is_home + R_diff +
    (1 | team) +          # attack (a_team)
    (1 | opponent) +
    (1 | team:time_idx) + 
    (1 | opponent:time_idx),      # opponent effect
  data = model_data_random_walk,
  family = negbinomial(),
  prior = priors_random_walk,
  chains = 4, cores = 4, iter = 4000,
  control = list(adapt_delta = 0.95, max_treedepth = 12)
)
```

```{r}
summary(fit_random_walk)
```

```{r}
plot(fit_random_walk)
```

