```{r goals modelling}
attack_data

set.seed(123)
cutoff <- as.Date("2024-08-01")

attack_train_data <- attack_data |>  filter(date < cutoff)
attack_test_data  <- attack_data |>  filter(date >= cutoff)

linreg_spec <- linear_reg() |> 
  set_engine("lm") |> 
  set_mode("regression")

metrics_reg <- metric_set(rmse, rsq, mae)

attack_rec <- recipe(ftg ~ ., data = attack_train_data) |> 
  step_impute_knn(all_numeric_predictors()) |> 
  step_rm(date, time, team_code) |> 
  step_novel(all_nominal_predictors()) |> 
  step_dummy(all_nominal_predictors()) |> 
  step_nzv(all_predictors()) |> 
  step_corr(all_numeric_predictors(), threshold = 0.9) |> 
  step_normalize(all_numeric_predictors())

attack_linreg_wf <- workflow() |> 
  add_model(linreg_spec) |> 
  add_recipe(attack_rec)

attack_fit <- fit(attack_linreg_wf, data = attack_train_data)

linreg_train_pred_attack <- predict(attack_fit, attack_train_data) |> 
  bind_cols(attack_train_data)

linreg_test_pred_attack <- predict(attack_fit, attack_test_data) |> 
  bind_cols(attack_test_data)

metrics(linreg_test_pred_attack, truth = ftg, estimate = .pred) |> 
  mutate(data = "test") |> 
  rbind(metrics(linreg_train_pred_attack, truth = ftg, estimate = .pred) |> 
          mutate(data = "train"))
```

