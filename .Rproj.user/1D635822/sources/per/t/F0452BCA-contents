```{r combining to get xG}
xg_test_data <- linreg_test_pred_defence |> 
  select(concede = .pred, date, time, home_away, team) |> 
  full_join(linreg_test_pred_attack |> 
              select(goal = .pred, date, time, home_away, team)) |> 
  select(concede, goal, everything()) |> 
  pivot_wider(names_from = home_away,
              values_from = c(concede, goal, team),
              names_glue = "{home_away}_{.value}") |> 
  unnest(cols = c(home_concede, away_concede, home_goal, away_goal, home_team, away_team)) |> 
  mutate(xg_home = (home_goal+away_concede)/2,
         xg_away = (away_goal+home_concede)/2,
         xdiff = xg_home-xg_away) |> 
  select(date, time, home_team, away_team, xg_home, xg_away, xdiff)

xg_train_data <- linreg_train_pred_defence |> 
  select(concede = .pred, date, time, home_away, team) |> 
  full_join(linreg_train_pred_attack |> 
              select(goal = .pred, date, time, home_away, team)) |> 
  select(concede, goal, everything()) |> 
  pivot_wider(names_from = home_away,
              values_from = c(concede, goal, team),
              names_glue = "{home_away}_{.value}") |> 
  unnest(cols = c(home_concede, away_concede, home_goal, away_goal, home_team, away_team)) |> 
  mutate(xg_home = (home_goal+away_concede)/2,
         xg_away = (away_goal+home_concede)/2,
         xdiff = xg_home-xg_away) |> 
  select(date, time, home_team, away_team, xg_home, xg_away, xdiff)
