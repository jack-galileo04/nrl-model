```{r Model Data}
# To model, impute NAs
# One-hot encode home_team, away_team, referee
# Do something with date and time
# scale numeric values
# split data

model_data <- eloform_df |>
  mutate(month = month(date),
         ftr = factor(ftr, levels = c("H", "D", "A")),
         home_team = factor(home_team),
         away_team = factor(away_team),
         referee = factor(referee)) |> 
  arrange(date) |> 
  mutate(month = format(date, "%Y-%m")) |> 
  rename(xg_home = fthg, xg_away = ftag, xdiff = ftgdiff) |> 
  select(b365h, b365a, b365d, bmgmh, bmgma, bmgmd, avg_h, avg_a, avg_d, max_h, max_a, max_d)

set.seed(123)
cutoff <- as.Date("2024-08-01")

train_data <- model_data |>  filter(date < cutoff)
test_data  <- model_data |>  filter(date >= cutoff)
test_data <- test_data |> 
  left_join(xg_test_data, by = c("date", "time", "home_team", "away_team")) |> 
  select(-xg_home.x, -xg_away.x, -xdiff.x) |> 
  rename(xg_home = xg_home.y, xg_away = xg_away.y, xdiff = xdiff.y) |> 
  select(xg_home, xg_away, everything())
train_data <- train_data |> 
  left_join(xg_train_data, by = c("date", "time", "home_team", "away_team")) |> 
  select(-xg_home.x, -xg_away.x, -xdiff.x) |> 
  rename(xg_home = xg_home.y, xg_away = xg_away.y, xdiff = xdiff.y) |> 
  select(xg_home, xg_away, everything())

N <- nrow(train_data)
initial <- floor(0.7*N)
assess <- floor(0.2*N)
splits <- 5
skip <- floor((N - initial - assess) / (splits - 1))

folds <- rolling_origin(
  data = train_data,
  initial = initial,   # adjust as needed
  assess = assess,
  skip = skip,
  cumulative = TRUE
)
```

```{r Log Reg}
# Recipe
recipe <- recipe(ftr ~ ., data = train_data) |> 
  step_impute_knn(all_numeric_predictors()) |> 
  step_rm(date, fthg, ftag, hst, ast, hs, as, ftgdiff, referee) |> 
  step_novel(all_nominal_predictors()) |> 
  step_dummy(all_nominal_predictors()) |> 
  step_zv(all_predictors()) |> 
  step_normalize(all_numeric_predictors())

# Model Spec
logreg_spec <- logistic_reg(penalty = tune(), mixture = 1) |> 
  set_engine("glmnet") |> 
  set_mode("classification")

# Workflow
wf_logreg_tune <- workflow() |> 
  add_recipe(recipe) |> 
  add_model(logreg_spec)

# Tune
penalty_grid <- grid_regular(
  penalty(range = c(-4, 0)),
  levels = 20
)

set.seed(789)
logreg_tune_rs <- tune_grid(
wf_logreg_tune,
resamples = folds,
metrics = metric_set(accuracy),
control = control_resamples(save_pred = TRUE),
grid = penalty_grid
)

best_params <- select_best(logreg_tune_rs, metric = "accuracy") # or "roc_auc" or "kap"
final_wf <- finalize_workflow(wf_logreg_tune, best_params)

# Finalise
final_fit <- fit(final_wf, data = train_data)

test_preds <- predict(final_fit, test_data, type = "prob") |> 
  bind_cols(predict(final_fit, test_data)) |> 
  bind_cols(test_data |>  select(home_team,away_team,ftr, b365h,b365d,b365a,bfdh,bfdd,bfda,bmgmh,bmgmd,bmgma,bvh,bvd,bva,bwh,bwd,bwa,clh,cld,cla,lbh,lbd,lba,psh,psd,psa,
                                 max_h,max_d,max_a,avg_h,avg_d,avg_a))

my_metrics <- metric_set(accuracy, roc_auc, sens, spec, mn_log_loss)
my_metrics(test_preds, truth = ftr, estimate = .pred_class, .pred_win)

# Profit if betting on B365
test_preds |> 
  mutate(ev_home = .pred_win * max_h - 1,
         ev_away = .pred_not_win * max_a - 1) |> 
  mutate(bet_home = ev_home > 0,
         bet_away = ev_away > 0,
         profit = case_when(
           bet_home & ftr == "win" ~ b365h - 1,
           bet_home & ftr != "win" ~ -1,
           bet_away & ftr == "not_win" ~ b365a - 1,
           bet_away & ftr != "not_win" ~ -1,
           T ~ 0
         )) |> 
  summarise(total_profit = sum(profit),
            total_stacked = sum(bet_home) + sum(bet_away),
            roi = total_profit/total_stacked)
```

```{r Rand For}
recipe <- recipe(ftr ~ ., data = train_data) |>
  step_rm(date, time, month, hst, ast, hs, as, referee) |> 
  step_impute_knn(all_numeric_predictors()) |> 
  step_novel(all_nominal_predictors()) |> 
  step_dummy(all_nominal_predictors()) |> 
  step_zv(all_predictors()) |> 
  step_normalize(all_numeric_predictors()) |> 
  step_YeoJohnson(all_numeric_predictors())

rf_spec <- rand_forest(
  mtry = tune(),
  min_n = tune(),
  trees = 500
) |> 
  set_engine("ranger") |> 
  set_mode("classification")

wf_randfor <- workflow() |> 
  add_model(rf_spec) |> 
  add_recipe(recipe)


rf_grid <- grid_regular(
  mtry(range = c(2, 8)),
  min_n(range = c(2, 10)),
  levels = 5
)

tune_res <- tune_grid(
  wf_randfor,
  resamples = folds,
  grid = rf_grid,
  metrics = metric_set(roc_auc, accuracy, mn_log_loss)
)

collect_metrics(tune_res) |> 
  group_by(.metric) |> 
  arrange(.metric, desc(mean))
best_params_rf <- select_best(tune_res, metric = "mn_log_loss")
final_wf_rf <- finalize_workflow(wf_randfor, best_params_rf)

# Finalise
final_fit_rf <- fit(final_wf_rf, data = train_data)

test_preds_rf <- predict(final_fit_rf, test_data, type = "prob") |> 
  bind_cols(predict(final_fit_rf, test_data)) |> 
  bind_cols(test_data |>  select(home_team,away_team,ftr, b365h,b365d,b365a,bfdh,bfdd,bfda,bmgmh,bmgmd,bmgma,bvh,bvd,bva,bwh,bwd,bwa,clh,cld,cla,lbh,lbd,lba,psh,psd,psa,
                                 max_h,max_d,max_a,avg_h,avg_d,avg_a))

my_metrics <- metric_set(accuracy, roc_auc, sens, spec, mn_log_loss)
my_metrics(test_preds_rf, truth = ftr, estimate = .pred_class, .pred_H, .pred_D, .pred_A)

# Profit if betting on B365
test_preds_rf |> 
  mutate(ev_home = .pred_H * max_h - 1,
         ev_draw = .pred_D * max_d - 1,
         ev_away = .pred_A * max_a - 1) |> 
  mutate(bet_home = ev_home > 0.05,
         bet_draw = ev_draw > 0.05,
         bet_away = ev_away > 0.05,
         profit = case_when(
           bet_home & ftr == "H" ~ max_h - 1,
           bet_home & ftr != "H" ~ -1,
           bet_draw & ftr == "D" ~ max_d - 1,
           bet_draw & ftr != "D" ~ -1,
           bet_away & ftr == "A" ~ max_a - 1,
           bet_away & ftr != "A" ~ -1,
           T ~ 0
         )) |> 
  summarise(total_profit = sum(profit),
            total_stacked = sum(bet_home) + sum(bet_away),
            roi = total_profit/total_stacked)
```

