```{r}
xgb_spec <- boost_tree(
  trees = 1000,
  tree_depth = tune(), min_n = tune(), loss_reduction = tune(),
  sample_size = tune(), mtry = tune(),
  learn_rate = tune()
) |> 
  set_engine("xgboost") |> 
  set_mode("classification")

rf_spec <- rand_forest(
  trees = 1000,
  mtry = tune(), min_n = tune()
) |> 
  set_engine("ranger") |> 
  set_mode("classification")

lasso_spec <- logistic_reg(
  penalty = tune(), 
  mixture = 1) |> 
  set_mode("classification") |> 
  set_engine("glmnet")
```


```{r}
# xgb Workflow

xgb_wf <- workflow() |> 
  add_model(xgb_spec) |> 
  add_recipe(xgb_rec)

sample_size_range <- dials::sample_prop(range = c(0.5, 0.9))

xgb_grid <- grid_space_filling(
  tree_depth(range = c(3,6)),
  min_n(),
  loss_reduction(),
  sample_size_range,
  mtry(c(40L, 85L)),
  learn_rate(),
  size = 20)
```

```{r}
# rf Workflow

rf_wf <- workflow() |> 
  add_model(rf_spec) |> 
  add_recipe(rf_rec)

rf_grid <- grid_space_filling(
  min_n(),
  mtry(c(40L, 85L)),
  size = 10)
```

```{r}
# lasso Workflwo

lasso_wf <- workflow() |> 
  add_model(lasso_spec) |> 
  add_recipe(lasso_rec)

lasso_grid <- grid_regular(
  penalty(),
  levels = 20
)
```


```{r}
# xgb fit

future::plan(multisession, workers = 4)

set.seed(123)
xgb_tune_res <- tune_grid(
  xgb_wf,
  resamples = folds,
  grid = xgb_grid,
  control = control_grid(verbose = TRUE, save_pred = TRUE),
  metrics = metric_set(mn_log_loss, brier_class)
)
saveRDS(xgb_tune_res, here(paste0("Outputs/xgb_tune_res_", format(Sys.Date()), ".rds")))

xgb_tune_res |> collect_metrics()

xgb_tune_res |> show_best(metric = "mn_log_loss")

xgb_best_logloss <- xgb_tune_res |> select_best(metric = "mn_log_loss")
```

```{r}
xgb_tune_res |> 
  collect_metrics() |> 
  filter(.metric == "mn_log_loss") |> 
  select(mean, mtry:sample_size) |> 
  pivot_longer(mtry:sample_size,
               names_to = "parameter",
               values_to = "value") |> 
  ggplot(aes(value, mean, color = parameter)) +
  geom_point() +
  facet_wrap(~parameter, scales = "free_x")

# Low loss reduction, 0.004 or above for learn rate
```


