```{r}
model_data <- combined_df |> 
  select(result, everything()) |> 
  mutate(result = factor(result), 
         result = ifelse(result == "H", "H", "A"))
```


```{r}
# Data Splitting and Folds

library(rsample)

cutoff <- as.Date("2024-02-01")

train_data <- model_data |>  filter(date < cutoff)
test_data  <- model_data |>  filter(date >= cutoff)

N <- nrow(train_data)
number_folds <- 5
assess <- 500
skip <- 100
initial <- -(number_folds*skip+assess-N)

folds <- rolling_origin(
  data = train_data,
  initial = initial,
  assess = assess,
  skip = skip,
  cumulative = TRUE
)
```


```{r}
