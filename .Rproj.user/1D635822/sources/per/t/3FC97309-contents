# Creating stack components

xgb_stack <- xgb_tune_res |> 
  collect_predictions() |> 
  inner_join(xgb_best_logloss) |> 
  select(id, .row, xgb = .pred_H, result)

rf_stack <- rf_tune_res |> 
  collect_predictions() |> 
  inner_join(rf_best_logloss) |> 
  select(id, .row, rf = .pred_H, result)

lasso_stack <- lasso_tune_res |> 
  collect_predictions() |> 
  inner_join(lasso_best_logloss) |> 
  select(id, .row, lasso = .pred_H, result)
```


```{r}
# Ensamble Data

stack_df <- xgb_stack |> 
  left_join(rf_stack) |> 
  left_join(lasso_stack) |> 
  select(-id, -.row)
```


```{r}
# Fit lasso to ensamble
stack_df
train_data

stack_model <- logistic_reg(penalty = tune(), mixture = tune()) |> 
  set_mode("classification") |> 
  set_engine("glmnet")

stack_rec <- recipe(result ~ ., data = stack_df) |> 
  step_normalize(all_predictors())

stack_wf <- workflow() |> 
  add_recipe(stack_rec) |> 
  add_model(stack_model)

stack_grid <- grid_regular(
  penalty(range = c(-6,0)),
  mixture(range = c(0,1)),
  levels = c(10,5)
)

metric_set <- metric_set(mn_log_loss, brier_class)

stack_res <- tune_grid(
  stack_wf, resamples = folds, grid = stack_grid, metrics = metric_set, control = control_grid(save_pred = TRUE)
)

